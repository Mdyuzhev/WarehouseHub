      "issues": [
        "Смотри GitHub Project"
      ],
      "testing": [
        "docs/TESTING.md",
        "docs/LOAD_TESTING.md"
      ],
      "architecture": [
        "docs/ARCHITECTURE.md",
        "docs/COMPONENTS.md"
      ],
      "troubleshooting": [
        "docs/TROUBLESHOOTING_GUIDE.md"
      ]
    }
  },
  "memory": {
    "server": "192.168.1.74, 24GB RAM, НЕ собирать Docker локально - OOM",
    "environments": {
      "prod": "namespace warehouse, порты 30xxx, deploy manual",
      "dev": "namespace warehouse-dev, порты 31xxx, deploy auto"
