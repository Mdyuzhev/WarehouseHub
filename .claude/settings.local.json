      },
      "rule": "Прочитай документы → Отправь справку → Начинай работу!"
    },
    "task_tracking": {
      "enabled": true,
      "tracker": "YouTrack",
      "tracker_url": "http://192.168.1.74:8088",
      "project_id": "0-1",
      "project_short": "WH",
      "auth_note": "ТОЛЬКО Basic Auth! Подробности в docs/YOUTRACK_API.md"
    },
    "session_start": {
      "description": "Выполнить при каждом старте работы",
      "steps": [
        "cd ~/warehouse-master && git pull origin main",
        "cat .claude/settings.local.json",
        "git status"
      ]
    },
    "task_start": {
      "description": "Выполнить перед началом задачи",
      "steps": [
        "Проверить что задача существует в YouTrack",
        "Создать ветку если нужно: git checkout -b feature/WH-XXX",
        "Прочитать описание задачи"
      ]
    },
    "task_end": {
      "description": "Выполнить после завершения задачи",
      "steps": [
        "git add .",
        "git commit -m '#WH-XXX Краткое описание на русском'",
        "git push origin main (или feature branch)",
        "Добавить комментарий в YouTrack с результатами",
        "Обновить документацию если нужно"
      ]
    },
    "deploy_note": "⚠️ Полные инструкции деплоя в docs/DEPLOY_GUIDE.md. K3s использует containerd, НЕ Docker!"
  },
