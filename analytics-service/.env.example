# =============================================================================
# Analytics Service Configuration
# WH-183: Скопируйте в .env и настройте под своё окружение
# Все переменные должны иметь префикс ANALYTICS_
# =============================================================================

# =============================================================================
# Kafka Configuration
# =============================================================================
ANALYTICS_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# В K8s: kafka.kafka.svc.cluster.local:9092
ANALYTICS_KAFKA_GROUP_ID=analytics-service
ANALYTICS_KAFKA_AUDIT_TOPIC=warehouse.audit
ANALYTICS_KAFKA_NOTIFICATIONS_TOPIC=warehouse.notifications

# =============================================================================
# Redis Configuration
# =============================================================================
ANALYTICS_REDIS_HOST=redis
# В K8s: redis.redis.svc.cluster.local
ANALYTICS_REDIS_PORT=6379
ANALYTICS_REDIS_DB=1                 # Отдельная БД для аналитики (0 = основное приложение)

# =============================================================================
# API Server Configuration
# =============================================================================
ANALYTICS_API_PORT=8090
ANALYTICS_API_HOST=0.0.0.0

# =============================================================================
# Aggregation Settings (WH-182: документация магических чисел)
# =============================================================================
# Окно агрегации метрик в секундах
# 60 сек - оптимальный баланс между точностью и нагрузкой
ANALYTICS_AGGREGATION_WINDOW_SECONDS=60

# Максимум событий в live feed (100 = ~10 сек истории при 10 RPS)
ANALYTICS_MAX_EVENTS_IN_FEED=100

# TTL статистики в Redis (86400 = 24 часа)
ANALYTICS_STATS_TTL_SECONDS=86400
