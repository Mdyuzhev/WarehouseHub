# PostgreSQL credentials for dev environment
# USAGE: Copy to postgres-secret.yaml and fill in actual passwords
# DO NOT commit postgres-secret.yaml to git!
---
apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: warehouse-dev
  labels:
    app: postgres
    environment: development
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: "<CHANGE_ME>"  # Set strong password
  APP_DB_NAME: warehouse_dev
  APP_DB_USER: warehouse_app
  APP_DB_PASSWORD: "<CHANGE_ME>"  # Set strong password for app user
  DATABASE_URL: "jdbc:postgresql://postgres-service:5432/warehouse_dev"
