# =============================================================================
# Uplink Bot Configuration
# =============================================================================

# Logging
LOG_FORMAT=text
LOG_LEVEL=INFO

# Uplink (Matrix messenger via botservice webhook)
UPLINK_WEBHOOK_URL=https://uplink.wh-lab.ru/hooks/wh_ci
UPLINK_WEBHOOK_TOKEN=warehouse-wh-ci-2026

# URLs - Homelab (docker-compose)
STAGING_API_URL=http://api:8080
STAGING_FRONTEND_URL=http://frontend:80

# URLs - Production (Yandex Cloud)
PROD_API_URL=https://api.wh-lab.ru
PROD_FRONTEND_URL=https://wh-lab.ru

# Health Check timeouts
HEALTH_CHECK_TIMEOUT=5.0
PROMETHEUS_TIMEOUT=3.0

# Prometheus
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_QUERY_WINDOW=5m

# App Lifecycle
GRACEFUL_SHUTDOWN_TIMEOUT=5.0

# Warehouse Robot
ROBOT_API_URL=
