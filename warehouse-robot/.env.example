# =============================================================================
# Warehouse Robot Configuration
# WH-183: Скопируйте в .env и настройте под своё окружение
# Все переменные должны иметь префикс ROBOT_
# =============================================================================

# =============================================================================
# Warehouse API URLs
# =============================================================================
ROBOT_API_URL_STAGING=http://warehouse-api-service.warehouse.svc.cluster.local:8080
ROBOT_API_URL_PROD=https://api.wh-lab.ru
ROBOT_API_URL=http://warehouse-api-service.warehouse.svc.cluster.local:8080  # Текущий URL
ROBOT_DEFAULT_ENVIRONMENT=staging    # staging или prod

# =============================================================================
# Учётные данные пользователей
# WH-174: Пароли читаются из env (K8s Secret)
# =============================================================================
ROBOT_EMPLOYEE_USERNAME=employee
ROBOT_EMPLOYEE_PASSWORD=password123  # Заменить на реальный в production!
ROBOT_MANAGER_USERNAME=manager
ROBOT_MANAGER_PASSWORD=password123   # Заменить на реальный в production!
ROBOT_SUPERUSER_USERNAME=superuser
ROBOT_SUPERUSER_PASSWORD=password123 # Заменить на реальный в production!

# =============================================================================
# Telegram Bot для уведомлений
# =============================================================================
ROBOT_TELEGRAM_BOT_URL=http://gitlab-telegram-bot.notifications.svc.cluster.local:8000

# =============================================================================
# API робота
# =============================================================================
ROBOT_API_PORT=8070

# =============================================================================
# HTTP таймауты (WH-179)
# =============================================================================
ROBOT_API_TIMEOUT=30.0               # Таймаут для CRUD операций (секунды)
ROBOT_HEALTH_TIMEOUT=5.0             # Таймаут для health check (секунды)
