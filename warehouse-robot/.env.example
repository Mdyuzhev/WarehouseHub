# =============================================================================
# Warehouse Robot Configuration
# All variables must have ROBOT_ prefix
# =============================================================================

# Warehouse API URLs
ROBOT_API_URL_HOME=http://api:8080
ROBOT_API_URL_PROD=https://api.wh-lab.ru
ROBOT_API_URL=http://api:8080
ROBOT_DEFAULT_ENVIRONMENT=home

# Credentials
ROBOT_EMPLOYEE_USERNAME=admin
ROBOT_EMPLOYEE_PASSWORD=admin123

# Telegram Bot notifications
ROBOT_TELEGRAM_BOT_URL=http://telegram-bot:8000

# Robot API port
ROBOT_API_PORT=8070

# HTTP timeouts (seconds)
ROBOT_API_TIMEOUT=30.0
ROBOT_HEALTH_TIMEOUT=5.0
