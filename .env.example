# Copy to .env — never commit .env to git

# Database password
DB_PASSWORD=change_me_strong_password

# JWT secret (generate: openssl rand -base64 64)
JWT_SECRET=change_me_generate_new_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Deploy password (for bot deploy commands)
DEPLOY_PASSWORD=change_me

# Uplink Bot (Matrix messenger)
UPLINK_WEBHOOK_URL=https://uplink.wh-lab.ru/hooks/wh_ci
UPLINK_WEBHOOK_TOKEN=warehouse-wh-ci-2026
