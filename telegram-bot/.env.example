# =============================================================================
# Telegram Bot Configuration
# WH-183: Скопируйте в .env и настройте под своё окружение
# =============================================================================

# =============================================================================
# Logging
# =============================================================================
LOG_FORMAT=text                    # "json" для K8s (Loki/ELK), "text" для локальной разработки
LOG_LEVEL=INFO                     # DEBUG, INFO, WARNING, ERROR

# =============================================================================
# Telegram (ОБЯЗАТЕЛЬНО)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
GITLAB_WEBHOOK_SECRET=               # Опционально: секрет для GitLab webhooks

# =============================================================================
# URLs - Staging (K8s internal DNS)
# =============================================================================
STAGING_API_URL=http://warehouse-api-service.warehouse.svc.cluster.local:8080
STAGING_FRONTEND_URL=http://warehouse-frontend-service.warehouse.svc.cluster.local

# =============================================================================
# URLs - Production (Yandex Cloud)
# =============================================================================
PROD_API_URL=https://api.wh-lab.ru
PROD_FRONTEND_URL=https://wh-lab.ru
PROD_HOST=130.193.44.34

# =============================================================================
# Locust (namespace loadtest)
# =============================================================================
LOCUST_MASTER_URL=http://locust-master.loadtest.svc.cluster.local:8089

# =============================================================================
# GitLab
# =============================================================================
GITLAB_URL=http://192.168.1.74:8080
GITLAB_TOKEN=your_gitlab_token_here  # Personal Access Token с api scope
GITLAB_TRIGGER_TOKEN=                 # Опционально: для pipeline triggers

# =============================================================================
# Allure
# =============================================================================
ALLURE_SERVER_URL=http://192.168.1.74:5050
ALLURE_PUBLIC_URL=https://your-allure-public-url.com

# =============================================================================
# Claude Proxy (опционально)
# =============================================================================
CLAUDE_PROXY_URL=http://192.168.1.74:8765

# =============================================================================
# Passwords (КРИТИЧНО - не коммитить реальные значения!)
# =============================================================================
DEPLOY_PASSWORD=your_deploy_password
LOAD_TEST_PASSWORD=your_load_test_password
LOAD_TEST_GUEST_PASSWORD=Guest       # Guest режим - не секрет

# =============================================================================
# Health Check таймауты (WH-180)
# =============================================================================
HEALTH_CHECK_TIMEOUT=5.0             # Таймаут проверки сервисов (секунды)
PROMETHEUS_TIMEOUT=3.0               # Таймаут запросов к Prometheus (секунды)

# =============================================================================
# App Lifecycle (WH-181)
# =============================================================================
GRACEFUL_SHUTDOWN_TIMEOUT=5.0        # Таймаут graceful shutdown (секунды)
MAX_BACKOFF_SECONDS=60               # Максимальная задержка при retry
INITIAL_BACKOFF_SECONDS=5            # Начальная задержка при retry

# =============================================================================
# Guest mode limits (WH-181)
# =============================================================================
GUEST_MAX_USERS=20                   # Максимум пользователей в guest режиме
GUEST_MAX_DURATION=300               # Максимальная длительность guest теста (сек)

# =============================================================================
# Prometheus
# =============================================================================
PROMETHEUS_URL=http://prometheus-kube-prometheus-prometheus.monitoring.svc.cluster.local:9090
PROMETHEUS_QUERY_WINDOW=5m           # Окно для метрик CPU/Memory

# =============================================================================
# YouTrack
# =============================================================================
YOUTRACK_URL=http://192.168.1.74:8088
YOUTRACK_USER=admin
YOUTRACK_PASSWORD=your_youtrack_password
YOUTRACK_PROJECT=WH

# =============================================================================
# Warehouse Robot
# =============================================================================
ROBOT_API_URL=http://warehouse-robot-service.warehouse.svc.cluster.local:8070
ROBOT_PASSWORD=your_robot_password

# =============================================================================
# WH-217: Load Testing Workflow
# =============================================================================

# Пароли для разных сред (раздельные для staging/prod)
LOAD_TEST_STAGING_PASSWORD=1              # Простой пароль для staging
LOAD_TEST_PROD_PASSWORD=your_prod_pass    # Надёжный пароль для prod (ОБЯЗАТЕЛЬНО!)

# Cooldown между тестами (защита от перегрузки)
COOLDOWN_MINUTES=30                       # Минут между запусками НТ

# =============================================================================
# WH-217: Cleanup Service Endpoints
# =============================================================================

# Redis
REDIS_STAGING_HOST=redis.warehouse.svc.cluster.local
REDIS_STAGING_PORT=6379
REDIS_PROD_HOST=localhost                 # Через SSH tunnel
REDIS_PROD_PORT=6379

# Kafka
KAFKA_STAGING_BROKERS=kafka.warehouse.svc.cluster.local:9092
KAFKA_PROD_BROKERS=                       # TODO: prod brokers

# PostgreSQL (connection strings)
POSTGRES_STAGING_URL=postgresql://warehouse:password@postgresql.warehouse.svc.cluster.local:5432/warehouse
POSTGRES_PROD_URL=                        # В K8s Secret
